^^ Uji Coba Matematika & Karma
takdir.hard tahun_lahir = 2004
takdir.soft tahun_sekarang = 2026
takdir.soft umur_asli = tahun_sekarang - tahun_lahir

ketik("Umur kamu adalah:")
ketik(umur_asli)

^^ Hakim Karma Bekerja
jika umur_asli > 17 maka
    ketik("Status: Kamu sudah dewasa, silakan masuk ke sistem!")
putus

jika umur_asli < 17 maka
    ketik("Status: Akses ditolak, kamu masih di bawah umur!")
putus