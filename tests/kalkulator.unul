^^ Uji Coba Kekuatan Matematika UNUL
takdir.hard tahun_lahir = 2004
takdir.soft tahun_sekarang = 2026

^^ Operasi pengurangan antar variabel
takdir.soft umur_asli = tahun_sekarang - tahun_lahir

ketik("=== MESIN WAKTU ===")
ketik("Tahun Kelahiran:")
ketik(tahun_lahir)
ketik("Umur di tahun 2026:")
ketik(umur_asli)