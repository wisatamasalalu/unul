ketik("=== MENGUJI OBJEK & API INTERNET ===")

^^ 1. Kita persiapkan data dalam bentuk JSON Teks Murni!
takdir.soft alamat_post = "https://httpbin.org/post"
takdir.soft data_user = "{\"nama\": \"Developer Kece\", \"sistem\": \"LinuxDNC\"}"

ketik("Mengirim data ke awan...")
