datang
ketik("Menyalakan Mesin Urantia TUI...")

takdir.soft gaya_global = muat_snul("kosmetik.snul")
takdir.soft aplikasi_hidup = 1
takdir.soft halaman_aktif = "gerbang"

siklus selama aplikasi_hidup == 1 maka
    coba maka
        
        ^^ ==========================================
        ^^ HALAMAN 1: GERBANG LOGIN
        ^^ ==========================================
        jika halaman_aktif == "gerbang" maka
            takdir.soft ui_gerbang = muat_otim("gerbang.otim")
            
            ^^ Tangkap Bungkusan Objek (Payload)
            takdir.soft form_gerbang = tampilkan_tui(ui_gerbang, gaya_global)

            ^^ EKSTRAK NILAINYA!
            takdir.soft aksi_tombol = form_gerbang.aksi
            takdir.soft sandi_input = form_gerbang.ui.anak_anak[1].anak_anak[3].anak_anak[1].isi

            jika aksi_tombol == "btn_masuk" maka
                jika sandi_input == "rahasia123" maka
                    halaman_aktif = "dasbor" ^^ TELEPORTASI!
                lain maka
                    ^^ Sandi salah, biarkan me-render ulang login
                putus
            putus

            jika aksi_tombol == "btn_keluar" atau aksi_tombol == "TUTUP_PAKSA" maka
                aplikasi_hidup = 0
            putus
            
            pasrah(ui_gerbang)
        putus

        ^^ ==========================================
        ^^ HALAMAN 2: DASBOR UTAMA
        ^^ ==========================================
        jika halaman_aktif == "dasbor" maka
            takdir.soft ui_dasbor = muat_otim("dasbor.otim")
            
            ^^ Tangkap Bungkusan Objek (Payload)
            takdir.soft form_dasbor = tampilkan_tui(ui_dasbor, gaya_global)

            ^^ EKSTRAK NILAINYA DARI OBJEK!
            takdir.soft aksi_dasbor = form_dasbor.aksi

            ^^ SEKARANG BANDINGKAN TEKS DENGAN TEKS!
            jika aksi_dasbor == "btn_logout" atau aksi_dasbor == "TUTUP_PAKSA" maka
                halaman_aktif = "gerbang" ^^ TENDANG KEMBALI KE LOGIN!
            putus
            
            pasrah(ui_dasbor)
        putus

    tabu melanggar e maka
        ketik("[KIAMAT SISTEM] " + e)
        aplikasi_hidup = 0
    pasrah

putus

pasrah(gaya_global)
ketik("\nSistem TUI Dimatikan dengan Aman. Sampai jumpa, Arsitek!")
pergi