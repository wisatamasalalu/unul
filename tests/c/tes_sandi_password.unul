datang
ketik("=== SISTEM KEAMANAN URANTIA OS ===")
ketik("Menginisiasi protokol perubahan sandi...\n")

takdir.soft status_berhasil = 0
takdir.soft sandi_final = ""

^^ Terus putar dimensi ini sampai user mengetik sandi yang cocok!
siklus selama status_berhasil == 0 maka
    
    ^^ bisik() akan meminta input tanpa menampilkan ketikan ke layar
    takdir.soft input_pertama = bisik("Masukkan sandi baru       : ")
    takdir.soft input_kedua = bisik("Ketik ulang sandi baru    : ")

    jika input_pertama == input_kedua maka
        ^^ Jika panjang sandi kosong, tolak!
        jika panjang(input_pertama) == 0 maka
            ketik("[DITOLAK] Sandi tidak boleh kosong!\n")
        lain maka
            sandi_final = input_pertama
            status_berhasil = 1
            ketik("\n[BERHASIL] Sandi Anda telah diperbarui dan disinkronkan!")
        putus
    lain maka
        ketik("[GAGAL] Sandi tidak sama! Silakan coba lagi.\n")
    putus

putus

^^ Di titik ini, Anda bisa menggunakan sandi_final 
^^ untuk dienkripsi ke file atau dikirim ke server!
^^ Contoh: tulis("sandi.txt", enkripsi(sandi_final, "kunci_rahasia"))

pasrah(input_pertama)
pasrah(input_kedua)
pergi